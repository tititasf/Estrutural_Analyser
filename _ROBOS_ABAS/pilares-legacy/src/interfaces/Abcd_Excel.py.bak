            'largura': 8,              # Largura
            'altura': 13,              # Altura
            
            # Painéis
            'laje_a': 14,              # Laje A
            'laje_b': 56,              # Laje B
            'laje_c': 98,              # Laje C
            'laje_d': 132,             # Laje D
            
