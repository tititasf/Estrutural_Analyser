            'parafuso_p8_p9': 181,  # Adicionado para P8-P9
            
            # Painel A - Larguras e Alturas
            'largura_1_painel_a': 16,  # Largura 1 A
            'largura_2_painel_a': 17,  # Largura 2 A
            'largura_3_painel_a': 18,  # Largura 3 A
            'altura_5_painel_a': 23,   # Altura 5 A
            'altura_4_painel_a': 22,   # Altura 4 A
            'altura_3_painel_a': 21,   # Altura 3 A
            'altura_2_painel_a': 20,   # Altura 2 A
            'altura_1_painel_a': 19,   # Altura 1 A

            # Aberturas A Esquerda
            'abertura_esq1_pos_a': 29,   # Posição Abertura 1 Esquerda A
            'abertura_esq1_dist_a': 26,  # Distância Abertura 1 Esquerda A
            'abertura_esq1_larg_a': 28,  # Largura Abertura 1 Esquerda A
            'abertura_esq1_prof_a': 27,  # Profundidade Abertura 1 Esquerda A
            'abertura_esq2_pos_a': 33,   # Posição Abertura 2 Esquerda A
            'abertura_esq2_dist_a': 30,  # Distância Abertura 2 Esquerda A
            'abertura_esq2_larg_a': 32,  # Largura Abertura 2 Esquerda A
            'abertura_esq2_prof_a': 31,  # Profundidade Abertura 2 Esquerda A

            # Aberturas A Direita
            'abertura_dir1_pos_a': 37,   # Posição Abertura 1 Direita A
            'abertura_dir1_dist_a': 34,  # Distância Abertura 1 Direita A
            'abertura_dir1_larg_a': 36,  # Largura Abertura 1 Direita A
            'abertura_dir1_prof_a': 35,  # Profundidade Abertura 1 Direita A
