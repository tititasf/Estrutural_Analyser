# Large DXF/DWG files from client projects (>80MB - exceeds GitHub limits)
**/Projetos_Finalizados_para_Engenharia_Reversa/*.dxf
**/Projetos_Finalizados_para_Engenharia_Reversa/*.dwg

# Large binary release artifacts
repository/targets/

# Large binary data files
project_data.vision

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Build/dist artifacts (todos ROBOS_ABAS - executaveis e compactados >80MB)
_ROBOS_ABAS/**/build/
_ROBOS_ABAS/**/dist/
_ROBOS_ABAS/**/Distribuicao*/
_ROBOS_ABAS/**/*.rar
_ROBOS_ABAS/**/*.zip
_ROBOS_ABAS/**/*.exe
_ROBOS_ABAS/**/*.pkg
